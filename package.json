{
  "name": "project-delivery-ux",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "concurrently --names proxy,ng --prefix-colors blue,green \"node dev-proxy.mjs\" \"ng serve\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:static": "vitest run --config vitest.static.config.ts",
    "e2e": "playwright test",
    "type-check": "node scripts/check-typescript.js",
    "lint:colors": "node scripts/check-modus-colors.js",
    "lint:styles": "node scripts/check-inline-styles.js",
    "lint:borders": "node scripts/check-border-violations.js",
    "lint:opacity": "node scripts/check-opacity-utilities.js",
    "lint:icons": "node scripts/check-modus-icons.js",
    "lint:icon-names": "node scripts/check-icon-names.js",
    "lint:semantic-html": "node scripts/check-semantic-html.js",
    "lint:all": "node scripts/run-all-checks.js",
    "dev:api": "vercel dev --listen 3001",
    "prepare": "husky || true"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@deepgram/sdk": "5.1.0",
    "@photo-sphere-viewer/core": "^5.11.5",
    "@trimble-oss/moduswebcomponents": "1.3.0",
    "@trimble-oss/moduswebcomponents-angular": "1.3.0-ng19",
    "@trimble-oss/trimble-id": "^1.0.1",
    "apexcharts": "^5.10.4",
    "ng-apexcharts": "^2.3.0",
    "pdfjs-dist": "4.10.38",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.8",
    "@angular/cli": "^20.3.8",
    "@angular/compiler-cli": "^20.3.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/node": "^25.5.2",
    "concurrently": "^9.2.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.16",
    "typescript": "~5.9.2",
    "vitest": "^3.1.4"
  }
}
