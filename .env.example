# Copy this file to .env and fill in your values.
# The .env file is gitignored -- NEVER commit real keys.
#
# These same variables must also be set in the Vercel project
# (Settings > Environment Variables) for Production and Preview.

# Anthropic Claude API -- used by api/chat.ts and dev-proxy.mjs
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenWeatherMap -- used by api/weather.ts and dev-proxy.mjs
# Get a key at https://home.openweathermap.org/api_keys
OPENWEATHERMAP_API_KEY=

# Deepgram -- used by api/deepgram-token.ts and dev-proxy.mjs to mint
# short-lived ephemeral tokens for browser voice-input (Nova-3 streaming STT).
# Master key never reaches the client; only the ~30-second JWT does.
# Get a key at https://console.deepgram.com/
DEEPGRAM_API_KEY=
